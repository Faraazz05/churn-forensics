# ══════════════════════════════════════════════════════════════
# Customer Health Forensics System — Root Environment Config
# Phase 8: Deployment
#
# Copy to .env and fill in your values.
# NEVER commit .env to Git — it is in .gitignore.
# ══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_NAME=Customer Health Forensics
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=3000

# ── Database ───────────────────────────────────────────────────
# SQLite (local dev — no setup required):
DATABASE_URL=sqlite:///./customer_health.db

# PostgreSQL (Docker Compose / production):
# DATABASE_URL=postgresql+asyncpg://churn_user:churn_pass@localhost:5432/customer_health

# PostgreSQL (Render managed DB):
# DATABASE_URL=postgresql+asyncpg://user:pass@host.render.com:5432/customer_health

# ── PostgreSQL (Docker Compose specific) ───────────────────────
POSTGRES_DB=customer_health
POSTGRES_USER=churn_user
POSTGRES_PASSWORD=churn_pass_change_in_prod

# ── Authentication ─────────────────────────────────────────────
API_KEY_ADMIN=admin-secret-key-change-in-production
API_KEY_READONLY=readonly-key-change-in-production
API_KEY_HEADER=X-API-Key

# ── LLM (Phase 5 integration) ──────────────────────────────────
# Options: rules (no LLM) | api (HuggingFace API) | local (local model)
LLM_MODE=rules
LLM_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2
HUGGINGFACEHUB_API_TOKEN=

# ── Pipeline config ────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
WATCHLIST_THRESHOLD=0.70
PIPELINE_TIMEOUT_S=1800

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend (Vite — used in Frontend/.env) ────────────────────
# These are referenced here for documentation.
# Actual frontend env is at Frontend/.env
# VITE_API_BASE_URL=http://localhost:3000
# VITE_API_KEY_ADMIN=admin-secret-key-change-in-production
# VITE_API_KEY_READONLY=readonly-key-change-in-production
# VITE_WATCHLIST_THRESHOLD=0.70
# VITE_APP_NAME=Customer Health Forensics

# ── Render deployment (production) ─────────────────────────────
# Set these in your Render service environment variables:
# DATABASE_URL=postgresql+asyncpg://...  (Render PostgreSQL URL)
# API_KEY_ADMIN=...
# API_KEY_READONLY=...
# LLM_MODE=rules
# PORT=3000
