# ══════════════════════════════════════════════════════════════
# Customer Health Forensics System — .gitignore
# ══════════════════════════════════════════════════════════════




# ── Logs ───────────────────────────────────────────────────────
logs/
*.log

# ── Environment files ──────────────────────────────────────────
.env
.env.local
.env.production
backend/.env
Frontend/.env
.sixth/

# Keep .env.example files (they are documentation)
!.env.example
!backend/.env.example
!Frontend/.env.example

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
notebooks/

# ── Virtual environments ────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/
.Customer/

# ── Jupyter notebooks checkpoints ──────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
notebooks/

# ── Node / Frontend ────────────────────────────────────────────
node_modules/
Frontend/node_modules/
Frontend/dist/
*.tsbuildinfo

# ── IDEs ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────────────
# Keep Dockerfiles tracked
!Dockerfile
!backend/Dockerfile
!docker/Dockerfile

# ── Database files (SQLite dev DB) ─────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Temporary files ────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── R ──────────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/

# ── Octave ─────────────────────────────────────────────────────
*.m~
octave-workspace


# --Large files (if any)──────────────────────────────────────────────
*.zip
*.tar.gz
*.rar

# DATA — never push (too large, not needed)
data/

# MODELS — now tracked via LFS (remove the ignore)
# models/    ← delete or comment out this line

# OUTPUTS — partially tracked, ignore the rest
outputs/_work/
outputs/reports/
outputs/segmentation/cohort_tables/
outputs/segmentation/cohort_report.xlsx
outputs/drift/psi_results.csv
outputs/drift/ks_results.csv
outputs/r_outputs/
outputs/octave_outputs/
outputs/insights_llm/
outputs/classification_report.txt
outputs/phase1_evaluation.png