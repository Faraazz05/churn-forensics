# ══════════════════════════════════════════════════════════════
# Customer Health Forensics System — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Data (too large for Git, generated by pipeline) ────────────
data/
uploads/
.sixth/

# ── ML Model artifacts (binary, generated) ─────────────────────
models/
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.ckpt

# ── Pipeline outputs (generated, not source) ───────────────────
outputs/

# ── Logs ───────────────────────────────────────────────────────
logs/
*.log

# ── Environment files ──────────────────────────────────────────
.env
.env.local
.env.production
backend/.env
Frontend/.env
# Keep .env.example files (they are documentation)
!.env.example
!backend/.env.example
!Frontend/.env.example

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
notebooks/

# ── Virtual environments ────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/
.Customer/

# ── Jupyter notebooks checkpoints ──────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
notebooks/

# ── Node / Frontend ────────────────────────────────────────────
node_modules/
Frontend/node_modules/
Frontend/dist/
*.tsbuildinfo

# ── IDEs ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────────────
# Keep Dockerfiles tracked
!Dockerfile
!backend/Dockerfile
!docker/Dockerfile

# ── Database files (SQLite dev DB) ─────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Temporary files ────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── R ──────────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/

# ── Octave ─────────────────────────────────────────────────────
*.m~
octave-workspace
